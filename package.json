{
  "name": "ring-of-steel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite --host 127.0.0.1 --port 5180 --strictPort",
    "dev:server": "node server.mjs",
    "dev:up": "powershell -ExecutionPolicy Bypass -File scripts/start-local-servers.ps1",
    "dev:check": "powershell -ExecutionPolicy Bypass -File scripts/check-local-servers.ps1",
    "dev:down": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-servers.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.mjs",
    "combat:baseline": "node scripts/print-combat-baseline.mjs",
    "sim:regression": "node scripts/combat-regression.mjs",
    "sim:selfplay": "node scripts/selfplay-tournament.mjs",
    "sim:analyze": "node scripts/analyze-selfplay.mjs",
    "stability:check": "npm run build && npm run sim:regression",
    "multiplayer:server": "node server/multiplayer-server.mjs",
    "multiplayer:smoke": "node scripts/smoke-multiplayer.mjs",
    "multiplayer:browser-smoke": "node scripts/smoke-online-browser.mjs",
    "multiplayer:public-ui-smoke": "node scripts/smoke-online-public-ui.mjs",
    "multiplayer:disconnect-smoke": "node scripts/smoke-online-disconnect.mjs",
    "generate:authoritative-tracks": "node scripts/generate-authoritative-tracks.mjs",
    "multiplayer:parity": "node scripts/check-fighter-parity.mjs",
    "multiplayer:check": "node scripts/check-multiplayer-safety.mjs",
    "multiplayer:bot-match": "node scripts/online-bot-match.mjs",
    "multiplayer:bot-matrix": "node scripts/online-bot-matrix.mjs",
    "multiplayer:bot-analyze": "node scripts/analyze-online-bot.mjs"
  },
  "dependencies": {
    "three": "^0.171.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "puppeteer": "^24.37.5",
    "vite": "^6.0.0"
  }
}
